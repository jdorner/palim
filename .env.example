# ============================================================================
# Palim – Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values.
#
# Legend:
#   [REQUIRED]  – You must set this for the app to work
#   [optional]  – Has a sensible default or enables an optional feature
# ============================================================================

# --- LLM Provider (REQUIRED) ------------------------------------------------
# Any OpenAI-compatible API endpoint works here:
#   • llama.cpp:         http://localhost:8080/v1
#   • llama-swap proxy:  http://localhost:11434/v1
#   • OpenAI:            https://api.openai.com/v1
#   • Together AI:       https://api.together.xyz/v1
#   • OpenRouter:        https://openrouter.ai/api/v1
#
# [REQUIRED] Base URL of the LLM API (must expose /v1/chat/completions)
OPENAI_API_BASE_URL=http://localhost:11434/v1

# [REQUIRED] API key for the LLM provider.
# For local llama.cpp you can use any non-empty string (e.g. "sk-local").
OPENAI_API_KEY=sk-local

# [optional] Default model to use. Fallback if no model has been configured through the web UI
# Examples: llama3, gpt-4o, meta-llama/Meta-Llama-3-70B-Instruct
OPENAI_DEFAULT_MODEL=

# --- Web Server (optional) ---------------------------------------------------
# [optional] Bind address and port for the web UI + API.
# Default: http://localhost:3000
WEB_SCHEME=http
WEB_HOST=localhost
WEB_PORT=3000

# --- Agent Workspace (optional) ----------------------------------------------
# [optional] Working directory the agent operates in (relative or absolute path).
# Default: .work/
AGENT_WORK_DIR=.work/

# --- Database (optional) -----------------------------------------------------
# [optional] Directory for SQLite databases (bunqueue.db, palim.db).
# Default: <AGENT_WORK_DIR>/.palim/
# DATA_DIR=.work/.palim

# --- Authentication (optional) -----------------------------------------------
# [optional] Bearer token for API and WebSocket auth.
# Leave empty to disable authentication (open access – fine for local use).
AUTH_TOKEN=

# --- Secret Vault (optional) -------------------------------------------------
# [optional] 32-byte master key for the encrypted secret vault (hex or base64).
# If not set, the key is derived automatically from .env.keys (if present).
# Only needed in environments without .env.keys (e.g. Docker, CI).
# Generate with: openssl rand -hex 32
SECRETS_MASTER_KEY=

# --- Workflow Templates (optional) -------------------------------------------
# [optional] Comma-separated list of extra env vars accessible via {{env.VAR}}
# in workflow templates. Built-in defaults: WEB_HOST, WEB_PORT, AGENT_WORK_DIR, NODE_ENV
WORKFLOW_ENV_ALLOWLIST=

# --- Debugging (optional) ----------------------------------------------------
# [optional] Debug log filter (e.g. DEBUG=* to show all logs)
DEBUG=
