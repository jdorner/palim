{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "html": {
    "formatter": {
      "enabled": true
    },
    "experimentalFullSupportEnabled": true
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "style": {
        "noNonNullAssertion": "off",
        "useConst": "error",
        "useNodejsImportProtocol": "on"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noControlCharactersInRegex": "off"
      }
    }
  },
  "assist": {
    "enabled": true,
    "includes": ["**"],
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "files": {
    "includes": ["**", "!node_modules", "!**/node_modules", "!frontend/node_modules", "!frontend/dist", "!.work"]
  },
  "overrides": [
    {
      "includes": ["frontend/src/**/*.svelte"],
      "linter": {
        "rules": {
          "a11y": {
            "useValidAriaValues": "off",
            "noStaticElementInteractions": "off"
          },
          "correctness": {
            "noUnusedVariables": "off"
          }
        }
      }
    },
    {
      "includes": ["src/extensions/*/index.ts", "src/extensions/*/*.ts", "src/extensions/*/skills/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@src/*"],
                    "message": "Extensions must not import from @src/. Use @ext/sdk, @ext/types, or ../types instead."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/extensions/*/skills/**/*.ts", "!src/extensions/skill-writing/skills/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "node:fs": "",
                  "node:fs/promises": ""
                }
              }
            }
          }
        }
      }
    }
  ]
}
